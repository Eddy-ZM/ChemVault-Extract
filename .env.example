# App
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.chemvault.science
ENABLE_API_DOCS=true

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_CHEMVAULT_USER_URL=https://user.chemvault.science

# Auth
JWT_SECRET=
JWT_EXPIRES_IN_MINUTES=10080
APP_ENCRYPTION_KEY=
ALLOW_USER_OPENAI_KEYS=true
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false
TURNSTILE_TIMEOUT_SECONDS=5.0
CHEMVAULT_USER_BASE_URL=https://user.chemvault.science
CHEMVAULT_USER_COOKIE_NAME=chemvault_session
CHEMVAULT_USER_COOKIE_DOMAIN=.chemvault.science
CHEMVAULT_USER_SERVICE_KEY=chemvault_extract
CHEMVAULT_USER_REQUIRE_SERVICE_ACCESS=false
CHEMVAULT_USER_TIMEOUT_SECONDS=5.0

# OpenAI
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_FALLBACK_MODEL=gpt-5.5
AI_MAX_CHUNKS_PER_DOCUMENT=20
AI_MAX_CHUNK_CHARS=6000
AI_ENABLE_FALLBACK_MODEL=false
AI_ESTIMATED_INPUT_TOKEN_RATIO=0.25
AI_MONTHLY_FREE_FILE_LIMIT=10
DEFAULT_FREE_MONTHLY_AI_FILE_LIMIT=10
DEFAULT_FREE_MONTHLY_AI_COST_LIMIT_USD=5.00

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/account/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/account/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/account/billing/cancel
STRIPE_PRICE_STUDENT_MONTHLY=
STRIPE_PRICE_RESEARCHER_MONTHLY=
STRIPE_PRICE_LAB_MONTHLY=
STRIPE_PRICE_STUDENT_YEARLY=
STRIPE_PRICE_RESEARCHER_YEARLY=
STRIPE_PRICE_LAB_YEARLY=

# Database
DATABASE_URL=postgresql+psycopg://chemvault:chemvault@postgres:5432/chemvault_extract
HYPERDRIVE_BINDING=
HYPERDRIVE_DATABASE_URL=

# Storage: local MinIO by default, Cloudflare R2 in production
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=chemvault
S3_SECRET_KEY=chemvault-secret
S3_BUCKET=chemvault-documents
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=chemvault
MINIO_SECRET_KEY=chemvault-secret
MINIO_BUCKET=chemvault-documents
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Queue: local Redis by default, Cloudflare Queues optional
QUEUE_PROVIDER=redis
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE=chemvault:extract:jobs
WEBHOOK_DELIVERY_QUEUE=chemvault:webhook:deliveries
CLOUDFLARE_QUEUE_NAME=
CLOUDFLARE_QUEUE_ID=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
INTERNAL_WORKER_TOKEN=

# Worker/runtime
WORKER_STEP_DELAY_SECONDS=1.0
MAX_CHUNK_TOKENS=900
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov
PUBCHEM_TIMEOUT_SECONDS=5.0
PUBCHEM_CACHE_TTL_SECONDS=3600
