# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_MODE=sunset
NEXT_PUBLIC_CHEMVAULT_LAB_URL=https://lab.chemvault.science
API_BASE_URL=http://localhost:8000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://app.chemvault.science
ENABLE_API_DOCS=true

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
NEXT_PUBLIC_CHEMVAULT_USER_URL=https://user.chemvault.science

# Auth
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRES_IN_MINUTES=10080
APP_ENCRYPTION_KEY=replace_with_secure_app_encryption_key
ALLOW_USER_OPENAI_KEYS=true
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key
TURNSTILE_REQUIRED=false
TURNSTILE_TIMEOUT_SECONDS=5.0
CHEMVAULT_USER_BASE_URL=https://user.chemvault.science
CHEMVAULT_USER_COOKIE_NAME=chemvault_session
CHEMVAULT_USER_COOKIE_DOMAIN=.chemvault.science
CHEMVAULT_USER_SERVICE_KEY=chemvault_extract
CHEMVAULT_USER_REQUIRE_SERVICE_ACCESS=false
CHEMVAULT_USER_TIMEOUT_SECONDS=5.0

# AI providers
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_FALLBACK_MODEL=gpt-5.5
AI_MAX_CHUNKS_PER_DOCUMENT=20
AI_MAX_CHUNK_CHARS=6000
AI_ENABLE_FALLBACK_MODEL=false
AI_ESTIMATED_INPUT_TOKEN_RATIO=0.25
AI_MONTHLY_FREE_FILE_LIMIT=10
DEFAULT_FREE_MONTHLY_AI_FILE_LIMIT=10
DEFAULT_FREE_MONTHLY_AI_COST_LIMIT_USD=5.00

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/account/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/account/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/account/billing/cancel
STRIPE_PRICE_STUDENT_MONTHLY=price_student_monthly_placeholder
STRIPE_PRICE_RESEARCHER_MONTHLY=price_researcher_monthly_placeholder
STRIPE_PRICE_LAB_MONTHLY=price_lab_monthly_placeholder
STRIPE_PRICE_STUDENT_YEARLY=price_student_yearly_placeholder
STRIPE_PRICE_RESEARCHER_YEARLY=price_researcher_yearly_placeholder
STRIPE_PRICE_LAB_YEARLY=price_lab_yearly_placeholder

# Database
DATABASE_URL=postgresql+psycopg://chemvault:chemvault@postgres:5432/chemvault_extract
HYPERDRIVE_BINDING=
HYPERDRIVE_DATABASE_URL=

# Storage: local MinIO by default, Cloudflare R2 in production
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=chemvault
S3_SECRET_KEY=dev_only_minio_secret_placeholder
S3_BUCKET=chemvault-documents
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=chemvault
MINIO_SECRET_KEY=dev_only_minio_secret_placeholder
MINIO_BUCKET=chemvault-documents
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=your_r2_bucket_name_here
R2_ENDPOINT=your_r2_endpoint_here
R2_PUBLIC_BASE_URL=

# Queue: local Redis by default, Cloudflare Queues optional
QUEUE_PROVIDER=redis
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE=chemvault:extract:jobs
WEBHOOK_DELIVERY_QUEUE=chemvault:webhook:deliveries
CLOUDFLARE_QUEUE_NAME=
CLOUDFLARE_QUEUE_ID=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=
INTERNAL_WORKER_TOKEN=replace_with_secure_internal_worker_token
LIFECYCLE_SERVICE_SECRET=replace_with_dedicated_cross_service_secret

# Worker/runtime
WORKER_STEP_DELAY_SECONDS=1.0
MAX_CHUNK_TOKENS=900
PUBCHEM_BASE_URL=https://pubchem.ncbi.nlm.nih.gov
PUBCHEM_TIMEOUT_SECONDS=5.0
PUBCHEM_CACHE_TTL_SECONDS=3600

# Optional email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
CONTACT_NOTIFICATION_EMAIL=
