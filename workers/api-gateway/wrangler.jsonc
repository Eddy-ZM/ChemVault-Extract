{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "chemvault-api-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-23",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "api.chemvault.science",
      "custom_domain": true
    }
  ],
  "vars": {
    "BACKEND_API_URL": "https://backend.example.com",
    "ALLOWED_ORIGINS": "https://app.chemvault.science,http://localhost:3000,http://127.0.0.1:3000"
  }
}
