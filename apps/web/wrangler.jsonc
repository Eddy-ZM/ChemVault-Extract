{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chemvault-extract-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-22",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "chemvault-extract-web"
    }
  ],
  "routes": [
    {
      "pattern": "app.chemvault.science",
      "custom_domain": true
    }
  ],
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://app.chemvault.science",
    "NEXT_PUBLIC_CHEMVAULT_LAB_URL": "https://lab.chemvault.science",
    "NEXT_PUBLIC_PRODUCT_MODE": "sunset",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": ""
  }
}
