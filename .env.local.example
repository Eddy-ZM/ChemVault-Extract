APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
NEXT_PUBLIC_CHEMVAULT_USER_URL=http://localhost:8788

DATABASE_URL=postgresql+psycopg://chemvault:chemvault@localhost:5432/chemvault_extract
QUEUE_PROVIDER=redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE=chemvault:extract:jobs
WEBHOOK_DELIVERY_QUEUE=chemvault:webhook:deliveries

STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=chemvault
MINIO_SECRET_KEY=dev_only_minio_secret_placeholder
MINIO_BUCKET=chemvault-documents
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=chemvault
S3_SECRET_KEY=dev_only_minio_secret_placeholder
S3_BUCKET=chemvault-documents

JWT_SECRET=replace_with_secure_jwt_secret
APP_ENCRYPTION_KEY=replace_with_secure_app_encryption_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key
TURNSTILE_REQUIRED=false
CHEMVAULT_USER_BASE_URL=http://localhost:8788
CHEMVAULT_USER_COOKIE_NAME=chemvault_session
CHEMVAULT_USER_COOKIE_DOMAIN=
CHEMVAULT_USER_SERVICE_KEY=chemvault_extract
CHEMVAULT_USER_REQUIRE_SERVICE_ACCESS=false
CHEMVAULT_USER_TIMEOUT_SECONDS=5.0
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_FALLBACK_MODEL=gpt-5.5
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
INTERNAL_WORKER_TOKEN=replace_with_secure_internal_worker_token

# Optional email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
CONTACT_NOTIFICATION_EMAIL=
